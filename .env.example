
# Environment variable names
PHP_CURRENT_VERSION_PATH='C:\pvm\php'
PVM_ENV_VAR_NAME='PVM'

# Fake drive path for tests (ex: 'TestDrive:')
TEST_DRIVE=null

# Cached available versions expiration in hours (default 1 week)
CACHE_MAX_HOURS=168

# Default page size for log display
DEFAULT_LOG_PAGE_SIZE=5

# Spacing / padding length
MIN_PAD_RIGHT_LENGTH=10
MIN_LINE_LENGTH=50

# Maximum number of items shown in partial version/extension lists
DEFAULT_PARTIAL_LIST_SIZE=10

# Update check configuration
ENABLE_UPDATE_CHECK=true
UPDATE_CHECK_INTERVAL_HOURS=24
